# --- Git LFS: heavy / binary artifacts ---
# Model adapters (Act 1 distilled LoRA) and any safetensors weights
artifacts/** filter=lfs diff=lfs merge=lfs -text
*.safetensors filter=lfs diff=lfs merge=lfs -text

# Training data (teacher-generated compression pairs) under data/ and the
# archived experiment runs. Scoped to these trees so small fixtures elsewhere
# (e.g. rezero/demo/scripted_convo.jsonl) stay regular, diffable files.
data/**/*.jsonl filter=lfs diff=lfs merge=lfs -text
experiments/**/*.jsonl filter=lfs diff=lfs merge=lfs -text

# Figures (the README / paper visuals)
*.png filter=lfs diff=lfs merge=lfs -text

# Large 5-bar eval result JSONs (~80-95 KB each). Small result JSONs
# (combined_benchmark, token_trajectory, latency, smoke) stay regular.
results/5bar_*.json filter=lfs diff=lfs merge=lfs -text

# Binary archives
*.zip filter=lfs diff=lfs merge=lfs -text
